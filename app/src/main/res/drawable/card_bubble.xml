<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1F1F1F" />
            <corners
                android:radius="30dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A0A0A" />
            <corners
                android:radius="30dp" />
        </shape>
    </item>

</layer-list>