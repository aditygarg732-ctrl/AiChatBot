<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/feedback_bg">

    <!-- Thank You Title -->
    <TextView
        android:id="@+id/thankYouTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="THANK YOU!"
        android:fontFamily="@font/shlop_rg"
        android:textColor="#8B1111"
        android:textSize="44sp"
        android:textStyle="bold"
        android:shadowColor="#FF4D4D"
        android:shadowRadius="2"
        android:shadowDx="0"
        android:shadowDy="0"
        android:layout_marginBottom="150dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Message -->
    <TextView
        android:id="@+id/below_thankYouTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FOR YOUR FEEDBACK"
        android:fontFamily="@font/shlop_rg"
        android:textColor="#8B1111"
        android:textSize="24sp"
        app:layout_constraintTop_toBottomOf="@id/thankYouTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"/>

    <!-- text layout -->
    <ImageView
        android:id="@+id/text_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/bg_of_text_feedback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/below_thankYouTitle"
        app:layout_constraintBottom_toTopOf="@+id/btnDialogOk"
        android:background="@android:color/transparent"/>

    <!-- text inside text layout -->
    <TextView
        android:id="@+id/text1TL"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your feedback has been sent successfully\nand is important to us."
        android:gravity="center"
        android:textSize="15sp"
        android:layout_marginTop="45dp"
        android:textColor="@color/white"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintTop_toTopOf="@+id/text_layout"
        app:layout_constraintBottom_toTopOf="@+id/text2TL"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/text2TL"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="It Will be Reviewed as Soon as Possible."
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="@color/white"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintTop_toBottomOf="@+id/text1TL"
        app:layout_constraintBottom_toTopOf="@+id/text3TL"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/text3TL"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="If the Developer is Free,\nYour feedback will be seen soon."
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="#C94B4B"
        app:layout_constraintTop_toBottomOf="@+id/text2TL"
        app:layout_constraintBottom_toBottomOf="@+id/text_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- OK Button -->
    <ImageButton
        android:id="@+id/btnDialogOk"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="80dp"
        android:layout_marginEnd="80dp"
        android:scaleType="fitXY"
        android:src="@drawable/done_feedback"/>

</androidx.constraintlayout.widget.ConstraintLayout>